# Secrets (à remplir sur ta VPS ou à adapter avant upload)
HF_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_API_KEY=

# Provider d'embeddings: huggingface ou openrouter
EMBEDDING_PROVIDER=huggingface

# URLs APIs (optionnel)
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_EMBEDDING_API_URL=https://openrouter.ai/api/v1/embeddings
HF_INFERENCE_ENDPOINT=https://api-inference.hf.co

# Logging & runtime (optionnel)
LOG_LEVEL=INFO
DEVICE=cpu

# Modèles (optionnel)
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
